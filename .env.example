# Anthropic (server-only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Supabase — required for persisting queries/reports (API uses service role; RLS has no anon policies)
# Project URL: Dashboard → Project Settings → API → Project URL
# Use either server-only SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL (same value).
SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# Service role secret (not the anon key): Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Optional: salt for SHA-256 of visitor IP (server-only). If unset, ip_hash is not stored.
# Raw IP is also stored on public.queries.ip when headers provide it — plan retention/consent accordingly.
# VISITOR_IP_SALT=
