# OpenAI (server-only)
OPENAI_API_KEY=

# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Supabase (URL is safe to expose; service role is server-only — never NEXT_PUBLIC)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: salt for SHA-256 of visitor IP (server-only). If unset, ip_hash is not stored.
# Raw IP is also stored on public.queries.ip when headers provide it — plan retention/consent accordingly.
# VISITOR_IP_SALT=
